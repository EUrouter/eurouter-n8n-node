{
	"name": "n8n-nodes-eurouter",
	"version": "1.1.0",
	"description": "n8n community node for EUrouter — the European AI gateway. 100+ models served from EU infrastructure with GDPR-friendly routing controls.",
	"license": "MIT",
	"homepage": "https://www.eurouter.ai",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"eurouter",
		"ai",
		"llm",
		"chat-model",
		"embeddings",
		"langchain",
		"agent",
		"vector-store",
		"rag",
		"openai-compatible",
		"claude",
		"mistral",
		"deepseek",
		"qwen",
		"llama",
		"eu",
		"gdpr",
		"data-residency",
		"sovereign-ai",
		"european-ai"
	],
	"author": {
		"name": "EUrouter",
		"email": "david@eurouter.ai",
		"url": "https://www.eurouter.ai"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/EUrouter/eurouter-n8n-node.git"
	},
	"bugs": {
		"url": "https://github.com/EUrouter/eurouter-n8n-node/issues"
	},
	"funding": {
		"type": "individual",
		"url": "https://www.eurouter.ai"
	},
	"scripts": {
		"build": "tsc && cp nodes/EUrouterChatModel/eurouter-icon.svg dist/nodes/EUrouterChatModel/ && cp nodes/EUrouterEmbeddings/eurouter-icon.svg dist/nodes/EUrouterEmbeddings/",
		"dev": "tsc --watch",
		"lint": "eslint . --ext .ts",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/EUrouterApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/EUrouterChatModel/EUrouterChatModel.node.js",
			"dist/nodes/EUrouterEmbeddings/EUrouterEmbeddings.node.js"
		]
	},
	"devDependencies": {
		"typescript": "~5.7.0",
		"@types/node": "^22.0.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*",
		"@langchain/openai": "*"
	}
}
